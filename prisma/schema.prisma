generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id           Int                  @id @default(autoincrement())
  modelName    String
  variant      String
  stock        ProductStock?
  transactions ProductTransaction[]

  @@unique([modelName, variant])
}

model Part {
  id           Int               @id @default(autoincrement())
  name         String            @unique
  unit         String            @default("EA")
  stock        PartStock?
  transactions PartTransaction[]
}

// 제품(모델) 현재고
model ProductStock {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId Int     @unique
  quantity  Int     @default(0)
}

// 부품 현재고
model PartStock {
  id       Int  @id @default(autoincrement())
  part     Part @relation(fields: [partId], references: [id])
  partId   Int  @unique
  quantity Int  @default(0)
}

// 제품 입출고 내역
model ProductTransaction {
  id               Int               @id @default(autoincrement())
  product          Product           @relation(fields: [productId], references: [id])
  productId        Int
  type             String            // "IN" | "OUT"
  quantity         Int
  note             String?
  usedParts        String?           // 사용 부품(자유 입력)
  createdAt        DateTime          @default(now())
  partTransactions PartTransaction[]
}

// 부품 입출고 내역
model PartTransaction {
  id                   Int                  @id @default(autoincrement())
  part                 Part                 @relation(fields: [partId], references: [id])
  partId               Int
  type                 String               // "IN" | "OUT"
  quantity             Int
  note                 String?
  createdAt            DateTime             @default(now())
  productTransaction   ProductTransaction?  @relation(fields: [productTransactionId], references: [id])
  productTransactionId Int?
}
